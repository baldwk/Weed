<Window x:Class="Weed.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Weed"
        Width="680"
        Height="520"
        MinWidth="560"
        MaxWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">
    <Border CornerRadius="8"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            SnapsToDevicePixels="True"
            MouseLeftButtonDown="DragSurface_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="26" ShadowDepth="10" Opacity="0.42" Color="#000000" />
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
                <RowDefinition Height="34" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="8"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="46" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="44" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="W"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             FontSize="25"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged"
                             PreviewKeyDown="SearchBox_PreviewKeyDown"
                             PreviewMouseDoubleClick="SearchBox_PreviewMouseDoubleClick" />
                    <Button Grid.Column="2"
                            Content="..."
                            FontSize="16"
                            ToolTip="Settings"
                            Click="Settings_Click"
                            Background="Transparent"
                            BorderThickness="0" />
                </Grid>
            </Border>

            <Grid x:Name="ResultsArea"
                  Grid.Row="1"
                  Margin="0,14,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="ResultsColumn" Width="*" />
                    <ColumnDefinition x:Name="PreviewColumn" Width="0" />
                </Grid.ColumnDefinitions>

                <ListBox x:Name="ResultsList"
                     Grid.Column="0"
                     Margin="0"
                     ItemsSource="{Binding Results}"
                     SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     ClipToBounds="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.ScrollChanged="ResultsList_ScrollChanged"
                     PreviewMouseMove="ResultsList_PreviewMouseMove"
                     PreviewMouseLeftButtonUp="ResultsList_PreviewMouseLeftButtonUp"
                     PreviewMouseRightButtonUp="ResultsList_PreviewMouseRightButtonUp">
                    <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="MinHeight" Value="52" />
                        <Setter Property="Margin" Value="1,0,1,6" />
                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderBrush" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#202630" />
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#384152" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#21372F" />
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#4F9E77" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="10,6"
                              Height="{Binding RowHeight}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="34"
                                    Height="34"
                                    CornerRadius="8"
                                    Background="{StaticResource SurfaceElevatedBrush}"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <Image Source="{Binding IconSource}"
                                           Width="24"
                                           Height="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock Text="{Binding IconGlyph}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                <Setter Property="FontSize" Value="12" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="FontFamily" Value="Segoe UI" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Result.Result.PluginId}" Value="weed.emoji">
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                        <Setter Property="FontFamily" Value="Segoe UI Emoji" />
                                                        <Setter Property="FontSize" Value="21" />
                                                        <Setter Property="FontWeight" Value="Normal" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Grid x:Name="StandardLayout"
                                  Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="82" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="15"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Subtitle}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12"
                                               Margin="0,4,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ActionHint}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Grid>
                    </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border x:Name="PreviewPanel"
                        Grid.Column="1"
                        Visibility="Collapsed"
                        Padding="12"
                        CornerRadius="8"
                        Background="{StaticResource BackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0"
                                    Margin="0,0,0,10">
                            <TextBlock Text="{Binding SelectedPreviewTitle}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding SelectedPreviewSubtitle}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       Margin="0,5,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Image Source="{Binding SelectedPreviewSource}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Stretch"
                                   VerticalAlignment="Top"
                                   RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPreviewHasImage}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <TextBox Text="{Binding SelectedPreviewText, Mode=OneWay}"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     FontSize="12"
                                     Padding="0,0,4,0"
                                     IsReadOnly="True"
                                     IsReadOnlyCaretVisible="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedPreviewHasText}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding Status}" />
                <TextBlock Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           MaxWidth="260"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding SelectedDetails}" />
            </Grid>
        </Grid>
    </Border>
</Window>

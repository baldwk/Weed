{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weed.local/schemas/plugin-registry.schema.json",
  "title": "Weed External Plugin Registry",
  "type": "object",
  "required": ["schemaVersion", "plugins"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string"
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "version", "packageUrl", "sha256"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9_.-]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "sdkVersion": {
            "type": "string"
          },
          "minWeedVersion": {
            "type": "string"
          },
          "packageUrl": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "repositoryUrl": {
            "type": "string"
          },
          "releaseNotesUrl": {
            "type": "string"
          },
          "trusted": {
            "type": "boolean",
            "default": true
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
